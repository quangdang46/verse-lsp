{
	"$schema": "https://raw.githubusercontent.com/microsoft/vscode-textmate/main/src/grammar.d.ts",
	"name": "verse",
	"scopeName": "source.verse",
	"fileTypes": ["verse"],
	"patterns": [
		{
			"include": "#comments"
		},
		{
			"include": "#module_paths"
		},
		{
			"include": "#attributes"
		},
		{
			"include": "#keywords"
		},
		{
			"include": "#declarations"
		},
		{
			"include": "#types"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#numbers"
		},
		{
			"include": "#operators"
		},
		{
			"include": "#function_calls"
		}
	],
	"repository": {
		"comments": {
			"name": "comment.line.verse",
			"match": "#.*$"
		},
		"module_paths": {
			"name": "string.quoted.other.verse",
			"match": "\\{[^}]+\\}"
		},
		"attributes": {
			"name": "entity.name.tag.verse",
			"match": "<[a-zA-Z_][a-zA-Z0-9_]*>"
		},
		"keywords": {
			"patterns": [
				{
					"name": "keyword.declaration.verse",
					"match": "\\b(module|class|enum|struct|interface|type)\\b"
				},
				{
					"name": "keyword.control.verse",
					"match": "\\b(if|else|for|while|loop|return|break|continue|match|switch|case|default|try|catch|throw|do|using|where|and|or|not|in|is|as|set|get)\\b"
				},
				{
					"name": "constant.language.verse",
					"match": "\\b(true|false|nil)\\b"
				}
			]
		},
		"declarations": {
			"name": "entity.name.declaration.verse",
			"match": "[a-zA-Z_][a-zA-Z0-9_]*\\s*:="
		},
		"types": {
			"patterns": [
				{
					"name": "support.type.primitive.verse",
					"match": "\\b(void|logic|int|float|string|message|agent|entity|component|var)\\b"
				},
				{
					"name": "entity.name.type.verse",
					"match": "\\b(tuple|listenable|generator|option|list|set|map|classifiable_subset)\\b"
				}
			]
		},
		"strings": {
			"name": "string.quoted.double.verse",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.verse",
					"match": "\\\\."
				}
			]
		},
		"numbers": {
			"patterns": [
				{
					"name": "constant.numeric.float.verse",
					"match": "\\b\\d+\\.\\d+\\b"
				},
				{
					"name": "constant.numeric.integer.verse",
					"match": "\\b\\d+\\b"
				}
			]
		},
		"operators": {
			"name": "keyword.operator.verse",
			"match": ":=|=|\\+=|-=|\\*=|/=|\\.\\.|->|<-|<:|>:|:"
		},
		"function_calls": {
			"name": "entity.name.function.verse",
			"match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\s*(?=\\()"
		}
	}
}