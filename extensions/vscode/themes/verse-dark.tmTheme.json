{
  "$schema": "vscode://schemas/color-theme",
  "name": "Verse-Dark",
  "tokenColors": [
    {"scope":"invalid.verse",              "settings": {"foreground":"#f44747", "fontStyle":""}},
    {"scope":"comment.block.verse",        "settings": {"foreground":"#77B06B", "fontStyle":""}},
    {"scope":"comment.line.verse",         "settings": {"foreground":"#77B06B", "fontStyle":""}},

    {"scope":"constant.language",         "settings": {"foreground":"#569cd6"}},
    {"scope":"constant.language.verse",   "settings": {"foreground":"#569cd6"}},
    {"scope":"constant.language.path.verse", "settings": {"foreground":"#b9d6ff", "fontStyle":""}},

    {"scope":"constant.numeric",          "settings": {"foreground":"#c2ddb4"}},
    {"scope":"constant.numeric.verse",    "settings": {"foreground":"#c2ddb4"}},

    {"scope":"constant.character.escape", "settings": {"foreground":"#B89047"}},
    {"scope":"constant.character.escape.verse", "settings": {"foreground":"#B89047"}},

    {"scope":"string",                    "settings": {"foreground":"#C09077"}},
    {"scope":"string.quoted.double.verse", "settings": {"foreground":"#C09077"}},
    {"scope":"string.quoted.single.verse", "settings": {"foreground":"#C09077"}},

    {"scope":"variable",                 "settings": {"foreground":"#b9d6ff"}},
    {"scope":"variable.verse",           "settings": {"foreground":"#b9d6ff"}},

    {"scope":"keyword",                  "settings": {"foreground":"#569cd6"}},
    {"scope":"keyword.control.verse",     "settings": {"foreground":"#569cd6"}},
    {"scope":"keyword.declaration.verse", "settings": {"foreground":"#8499b7"}},
    {"scope":"keyword.operator.verse",   "settings": {"foreground":"#77AFAF"}},
    {"scope":"keyword.operator.logical.verse", "settings": {"foreground":"#77AFAF"}},
    {"scope":"keyword.operator.arithmetic.verse", "settings": {"foreground":"#77AFAF"}},
    {"scope":"keyword.operator.comparison.verse", "settings": {"foreground":"#77AFAF"}},

    {"scope":"entity.name.function",     "settings": {"foreground":"#e5c2ff"}},
    {"scope":"entity.name.function.verse", "settings": {"foreground":"#e5c2ff"}},
    {"scope":"entity.name.tag.verse",     "settings": {"foreground":"#6F77A6"}},
    {"scope":"entity.name.type.verse",    "settings": {"foreground":"#4EC9B0"}},

    {"scope":"support.type",             "settings": {"foreground":"#4EC9B0"}},
    {"scope":"support.type.primitive.verse", "settings": {"foreground":"#4EC9B0"}},
    {"scope":"support.type.verse",       "settings": {"foreground":"#4EC9B0"}},

    {"scope":"punctuation.definition.tag", "settings": {"foreground":"#8499b7"}},

    {"scope":"meta.indent.verse",        "settings": {"foreground":"#DFC79F", "fontStyle":"italic"}},

    {"scope":"text.verse",               "settings": {"foreground":"#DFC79F", "fontStyle":"italic"}}
  ]
}